{{- /* =============================================================================
   spring/vault/secrets.ctmpl

   Consul Template rendered by Vault Agent into:
     /secrets/vault-secrets.properties

   This file contains ONLY credentials — nothing else. All non-secret
   configuration (datasource URL, driver class, JPA settings, actuator config)
   lives in the committed base file:
     src/main/resources/application.properties

   Spring Boot merges both files via spring.config.import. The base file
   provides safe defaults; this file supplies only the keys that must stay
   out of source control.

   Two secret sources:
     1. Static secrets  — KV v2 at spring/kv/data/payments-app
        custom.StaticSecret.username / .password
     2. Dynamic secrets — database/creds/payments-app
        spring.datasource.username / .password (short-lived PostgreSQL creds)

   After each re-render Vault Agent calls POST /actuator/refresh so Spring
   re-binds all @RefreshScope beans with the updated values.
   ============================================================================= */ -}}

{{- /* -------------------------------------------------------------------------
   Static secrets from KV v2.
   .Data.data is used because KV v2 wraps values under a nested "data" key.
   ------------------------------------------------------------------------- */ -}}
{{ with secret "spring/kv/data/payments-app" -}}
custom.static-secret.username={{ index .Data.data "custom.static-secret.username" }}
custom.static-secret.password={{ index .Data.data "custom.static-secret.password" }}
{{ end -}}

{{- /* -------------------------------------------------------------------------
   Dynamic database credentials from the database secrets engine.
   Vault issues a fresh username/password pair on each render. The DataSource
   @RefreshScope bean is replaced with a new HikariCP pool on /actuator/refresh.
   ------------------------------------------------------------------------- */ -}}
{{ with secret "database/creds/payments-app" -}}
spring.datasource.username={{ .Data.username }}
spring.datasource.password={{ .Data.password }}
{{ end -}}
