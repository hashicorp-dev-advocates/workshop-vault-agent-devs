# =============================================================================
# Runtime secrets written by Vault Agent — never commit these
# =============================================================================
secrets/*
!secrets/.gitkeep

# =============================================================================
# Spring Boot / Maven
# =============================================================================

# Compiled output
target/
*.class

# Maven wrapper cache
.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/maven-wrapper.properties

# Spring Boot fat JAR (built by Docker, not committed)
*.jar
*.war

# Spring Boot DevTools restart trigger
.spring-boot-devtools.properties

# Spring configuration override (should be environment-specific)
application-local.properties
application-local.yml

# =============================================================================
# IDEs
# =============================================================================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse / STS
.classpath
.project
.settings/
.apt_generated/
.factorypath

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# NetBeans
nbproject/
build/
nbbuild/
dist/
nbdist/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================================
# Linux / Windows
# =============================================================================
*~
Thumbs.db
ehthumbs.db

# =============================================================================
# Docker
# =============================================================================
# Ignore local override compose files
docker-compose.override.yml
# k3s runtime files
tmp/


instruqt/track.yml