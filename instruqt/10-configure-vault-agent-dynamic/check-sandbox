#!/bin/bash
set -euxo pipefail

set-workdir /root/workshop-vault-agent-devs

if ! grep -q 'database/creds/writer' spring/vault/secrets.ctmpl; then
    fail-message "Add the \`database/creds/writer\` block to \`spring/vault/secrets.ctmpl\`"
fi

if ! grep -q 'spring.datasource.username' spring/vault/secrets.ctmpl; then
    fail-message "Render \`spring.datasource.username\` from the database credentials block"
fi
